generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TruckStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SOLD
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  TERMINAL
  DEPOT
  CUSTOMER_SITE
  PORT
  OTHER
}

enum CourseStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INVOICED
}

enum CustomerBillableKmLogic {
  TOTAL_ROUTE
  ONE_WAY
  SELECTED_LEGS
  FIXED_PRICE
  MANUAL
}

enum TariffType {
  FIXED_TABLE_UPPER_BOUND
  DISTANCE_TABLE
  PRICE_PER_KM
  FIXED_PRICE
  SHUNT
  WAITING_TIME
  MANUAL
}

enum CostType {
  FUEL
  TOLL
  PORT_FEE
  REPAIR
  WASH
  PARKING
  DRIVER_COST
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentType {
  CMR
  INVOICE
  POD
  PHOTO
  OTHER
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model Company {
  id                 String        @id @default(cuid())
  name               String        @unique
  legalName          String?
  vatNumber          String?
  registrationNumber String?
  email              String?
  phone              String?
  website            String?

  street             String?
  city               String?
  postalCode         String?
  country            String        @default("BG")

  status             CompanyStatus @default(ACTIVE)
  notes              String?

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([status])
}

model AppSetting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       String
  valueType   SettingValueType @default(STRING)
  description String?
  group       String?
  isPublic    Boolean          @default(false)

  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([group])
  @@index([key])
}

model Customer {
  id                 String                  @id @default(cuid())
  name               String                  @unique
  email              String?
  phone              String?
  vatNumber          String?
  status             CustomerStatus          @default(ACTIVE)
  billableKmLogic    CustomerBillableKmLogic @default(TOTAL_ROUTE)
  notes              String?

  addresses          CustomerAddress[]
  tariffs            CustomerTariff[]
  courses            Course[]
  invoices           Invoice[]

  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@index([name])
}

model Address {
  id                 String            @id @default(cuid())
  name               String
  street             String?
  city               String?
  postalCode         String?
  country            String
  type               AddressType       @default(OTHER)
  portCode           String?
  terminalCode       String?
  notes              String?

  customerAddresses  CustomerAddress[]

  pickupCourses      Course[]          @relation("CoursePickupAddress")
  deliveryCourses    Course[]          @relation("CourseDeliveryAddress")

  routeLegsFrom      RouteLeg[]        @relation("RouteLegFromAddress")
  routeLegsTo        RouteLeg[]        @relation("RouteLegToAddress")

  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  @@index([city, country])
  @@index([name])
}

model CustomerAddress {
  id                 String    @id @default(cuid())
  customerId         String
  addressId          String
  isDefault          Boolean   @default(false)
  notes              String?

  customer           Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address            Address   @relation(fields: [addressId], references: [id], onDelete: Cascade)

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([customerId, addressId])
  @@index([customerId])
  @@index([addressId])
}

model Truck {
  id                              String       @id @default(cuid())
  name                            String
  licensePlate                    String       @unique
  vin                             String?
  status                          TruckStatus  @default(ACTIVE)

  euroClass                       String       @default("Euro 6")
  defaultFuelConsumptionLPer100Km Decimal      @default(30) @db.Decimal(10, 2)

  notes                           String?

  courses                         Course[]
  costs                           Cost[]

  createdAt                       DateTime     @default(now())
  updatedAt                       DateTime     @updatedAt

  @@index([name])
  @@index([status])
}

model Driver {
  id                 String        @id @default(cuid())
  firstName          String
  lastName           String
  phone              String?
  email              String?
  status             DriverStatus  @default(ACTIVE)
  notes              String?

  courses            Course[]

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([lastName, firstName])
}

model CustomerTariff {
  id                 String                  @id @default(cuid())
  customerId         String
  type               TariffType
  billableKmLogic    CustomerBillableKmLogic @default(TOTAL_ROUTE)

  name               String
  minKm              Decimal?                @db.Decimal(10, 2)
  maxKm              Decimal?                @db.Decimal(10, 2)
  fixedPrice         Decimal?                @db.Decimal(12, 2)
  pricePerKm         Decimal?                @db.Decimal(12, 4)
  waitingHourlyRate  Decimal?                @db.Decimal(12, 2)
  portFeeIncluded    Boolean                 @default(false)
  isActive           Boolean                 @default(true)
  notes              String?

  customer           Customer                @relation(fields: [customerId], references: [id], onDelete: Cascade)

  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt

  @@unique([customerId, name])
  @@index([customerId])
  @@index([type])
}

model Course {
  id                 String        @id @default(cuid())
  courseNumber       String?       @unique
  customerId         String
  truckId            String?
  driverId           String?

  pickupAddressId    String?
  deliveryAddressId  String?

  status             CourseStatus  @default(DRAFT)

  plannedDate        DateTime?
  startedAt          DateTime?
  completedAt        DateTime?

  containerNumber    String?
  bookingNumber      String?
  referenceNumber    String?
  tarCode            String?
  acceptanceRef      String?

  totalKm            Decimal?      @db.Decimal(10, 2)
  billableKm         Decimal?      @db.Decimal(10, 2)
  nonBillableKm      Decimal?      @db.Decimal(10, 2)

  kmSource           String?
  manualKmOverride   Boolean       @default(false)
  kmOverrideNotes    String?

  agreedPrice        Decimal?      @db.Decimal(12, 2)
  waitingHours       Decimal?      @db.Decimal(10, 2)
  waitingAmount      Decimal?      @db.Decimal(12, 2)
  portFeeAmount      Decimal?      @db.Decimal(12, 2)

  notes              String?

  customer           Customer      @relation(fields: [customerId], references: [id])
  truck              Truck?        @relation(fields: [truckId], references: [id])
  driver             Driver?       @relation(fields: [driverId], references: [id])

  pickupAddress      Address?      @relation("CoursePickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddress    Address?      @relation("CourseDeliveryAddress", fields: [deliveryAddressId], references: [id])

  routeLegs          RouteLeg[]
  costs              Cost[]
  invoiceLines       InvoiceLine[]
  documents          Document[]

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([customerId])
  @@index([truckId])
  @@index([driverId])
  @@index([plannedDate])
  @@index([status])
}

model RouteLeg {
  id                 String    @id @default(cuid())
  courseId           String
  sequence           Int

  fromAddressId      String?
  toAddressId        String?

  description        String?
  totalDistanceKm    Decimal?  @db.Decimal(10, 2)
  billableDistanceKm Decimal?  @db.Decimal(10, 2)
  isBillable         Boolean   @default(true)
  notes              String?

  course             Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fromAddress        Address?  @relation("RouteLegFromAddress", fields: [fromAddressId], references: [id])
  toAddress          Address?  @relation("RouteLegToAddress", fields: [toAddressId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([courseId, sequence])
  @@index([courseId])
}

model Cost {
  id                 String    @id @default(cuid())
  courseId           String?
  truckId            String?
  type               CostType
  description        String
  amount             Decimal   @db.Decimal(12, 2)
  costDate           DateTime  @default(now())
  notes              String?

  course             Course?   @relation(fields: [courseId], references: [id])
  truck              Truck?    @relation(fields: [truckId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([courseId])
  @@index([truckId])
  @@index([type])
  @@index([costDate])
}

model Invoice {
  id                 String        @id @default(cuid())
  invoiceNumber      String        @unique
  customerId         String
  status             InvoiceStatus @default(DRAFT)

  issueDate          DateTime      @default(now())
  dueDate            DateTime?
  paidAt             DateTime?

  periodStart        DateTime?
  periodEnd          DateTime?

  subtotalAmount     Decimal       @default(0) @db.Decimal(12, 2)
  vatAmount          Decimal       @default(0) @db.Decimal(12, 2)
  totalAmount        Decimal       @default(0) @db.Decimal(12, 2)

  notes              String?

  customer           Customer      @relation(fields: [customerId], references: [id])
  lines              InvoiceLine[]
  documents          Document[]

  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceLine {
  id                 String    @id @default(cuid())
  invoiceId          String
  courseId           String?

  description        String
  quantity           Decimal   @default(1) @db.Decimal(10, 2)
  unitPrice          Decimal   @db.Decimal(12, 2)
  totalPrice         Decimal   @db.Decimal(12, 2)

  invoice            Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  course             Course?   @relation(fields: [courseId], references: [id])

  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([invoiceId])
  @@index([courseId])
}

model Document {
  id                 String       @id @default(cuid())
  courseId           String?
  invoiceId          String?

  type               DocumentType
  fileName           String
  fileUrl            String?
  notes              String?

  course             Course?      @relation(fields: [courseId], references: [id])
  invoice            Invoice?     @relation(fields: [invoiceId], references: [id])

  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([courseId])
  @@index([invoiceId])
  @@index([type])
}