generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TruckStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  SOLD
}

enum DriverStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
}

enum CustomerStatus {
  ACTIVE
  INACTIVE
}

enum CompanyStatus {
  ACTIVE
  INACTIVE
}

enum AddressType {
  TERMINAL
  DEPOT
  CUSTOMER_SITE
  PORT
  OTHER
}

enum CourseStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  INVOICED
}

enum SettlementStatus {
  NOT_CHECKED
  OK
  UNDERPAID
  OVERPAID
  DISPUTED
}

enum CourseType {
  ROUND_TRIP
  SHUNT
}

enum CourseStopType {
  PICKUP
  LOAD_UNLOAD
  EXTRA
  RETURN
}

enum CustomerBillableKmLogic {
  TOTAL_ROUTE
  ONE_WAY
  SELECTED_LEGS
  FIXED_PRICE
  MANUAL
}

enum TariffType {
  FIXED_TABLE_UPPER_BOUND
  DISTANCE_TABLE
  PRICE_PER_KM
  FIXED_PRICE
  SHUNT
  WAITING_TIME
  MANUAL
}

enum CostType {
  FUEL
  TOLL
  PORT_FEE
  REPAIR
  WASH
  PARKING
  DRIVER_COST
  OTHER
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  CANCELLED
}

enum DocumentType {
  CMR
  INVOICE
  POD
  PHOTO
  OTHER
}

enum SettingValueType {
  STRING
  NUMBER
  BOOLEAN
  JSON
}

model Company {
  id                 String  @id @default(cuid())
  name               String  @unique
  legalName          String?
  vatNumber          String?
  registrationNumber String?
  email              String?
  phone              String?
  website            String?

  street     String?
  city       String?
  postalCode String?
  country    String  @default("BG")

  status CompanyStatus @default(ACTIVE)
  notes  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

model AppSetting {
  id          String           @id @default(cuid())
  key         String           @unique
  value       String
  valueType   SettingValueType @default(STRING)
  description String?
  group       String?
  isPublic    Boolean          @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([group])
  @@index([key])
}

model Customer {
  id              String                  @id @default(cuid())
  name            String                  @unique
  email           String?
  phone           String?
  vatNumber       String?
  status          CustomerStatus          @default(ACTIVE)
  billableKmLogic CustomerBillableKmLogic @default(TOTAL_ROUTE)
  notes           String?

  addresses CustomerAddress[]
  tariffs   CustomerTariff[]
  courses   Course[]
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
}

model Address {
  id           String      @id @default(cuid())
  name         String
  street       String?
  city         String?
  postalCode   String?
  country      String
  latitude     Decimal?    @db.Decimal(10, 7)
  longitude    Decimal?    @db.Decimal(10, 7)
  type         AddressType @default(OTHER)
  portCode     String?
  terminalCode String?
  isActive     Boolean     @default(true)
  notes        String      @default("")

  customerAddresses CustomerAddress[]

  pickupCourses   Course[] @relation("CoursePickupAddress")
  deliveryCourses Course[] @relation("CourseDeliveryAddress")

  routeLegsFrom RouteLeg[] @relation("RouteLegFromAddress")
  routeLegsTo   RouteLeg[] @relation("RouteLegToAddress")

  courseStops CourseStop[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([city, country])
  @@index([name])
  @@index([type])
  @@index([isActive])
}

model CustomerAddress {
  id         String  @id @default(cuid())
  customerId String
  addressId  String
  isDefault  Boolean @default(false)
  notes      String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  address  Address  @relation(fields: [addressId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, addressId])
  @@index([customerId])
  @@index([addressId])
}

model Truck {
  id           String      @id @default(cuid())
  name         String
  licensePlate String      @unique
  vin          String?
  status       TruckStatus @default(ACTIVE)

  euroClass                       String  @default("Euro 6")
  defaultFuelConsumptionLPer100Km Decimal @default(30) @db.Decimal(10, 2)

  monthlyLeaseCost      Decimal @default(0) @db.Decimal(12, 2)
  monthlyInsuranceCost  Decimal @default(0) @db.Decimal(12, 2)
  monthlyRoadTaxCost    Decimal @default(0) @db.Decimal(12, 2)
  monthlyOtherFixedCost Decimal @default(0) @db.Decimal(12, 2)

  notes String?

  courses              Course[]
  costs                Cost[]
  weeklyRevenueReports WeeklyTruckRevenueReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([name])
  @@index([status])
}

model Driver {
  id        String       @id @default(cuid())
  firstName String
  lastName  String
  phone     String?
  email     String?
  status    DriverStatus @default(ACTIVE)
  notes     String?

  courses Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([lastName, firstName])
}

model CustomerTariff {
  id              String                  @id @default(cuid())
  customerId      String
  type            TariffType
  billableKmLogic CustomerBillableKmLogic @default(TOTAL_ROUTE)

  name              String
  minKm             Decimal? @db.Decimal(10, 2)
  maxKm             Decimal? @db.Decimal(10, 2)
  fixedPrice        Decimal? @db.Decimal(12, 2)
  pricePerKm        Decimal? @db.Decimal(12, 4)
  waitingHourlyRate Decimal? @db.Decimal(12, 2)
  portFeeIncluded   Boolean  @default(false)
  isActive          Boolean  @default(true)
  notes             String?

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  courses  Course[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([customerId, name])
  @@index([customerId])
  @@index([type])
}

model Course {
  id               String  @id @default(cuid())
  courseNumber     String? @unique
  customerId       String
  customerTariffId String?
  truckId          String?
  driverId         String?

  courseType CourseType @default(ROUND_TRIP)

  pickupAddressId   String?
  deliveryAddressId String?

  status CourseStatus @default(DRAFT)

  plannedDate DateTime?
  startedAt   DateTime?
  completedAt DateTime?

  containerNumber String?
  bookingNumber   String?
  referenceNumber String?
  tarCode         String?
  acceptanceRef   String?

  totalKm       Decimal? @db.Decimal(10, 2)
  billableKm    Decimal? @db.Decimal(10, 2)
  nonBillableKm Decimal? @db.Decimal(10, 2)

  kmSource         String?
  manualKmOverride Boolean @default(false)
  kmOverrideNotes  String?

  agreedPrice   Decimal? @db.Decimal(12, 2)
  waitingHours  Decimal? @db.Decimal(10, 2)
  waitingAmount Decimal? @db.Decimal(12, 2)
  portFeeAmount Decimal? @db.Decimal(12, 2)

  settlementAmount    Decimal?         @db.Decimal(12, 2)
  settlementStatus    SettlementStatus @default(NOT_CHECKED)
  settlementCheckedAt DateTime?
  settlementReference String?
  settlementNotes     String?

  tariffNameAtBooking        String?
  tariffTypeAtBooking        TariffType?
  pricingMethodAtBooking     String?
  pricePerKmAtBooking        Decimal?                 @db.Decimal(12, 4)
  fixedPriceAtBooking        Decimal?                 @db.Decimal(12, 2)
  waitingHourlyRateAtBooking Decimal?                 @db.Decimal(12, 2)
  billableKmLogicAtBooking   CustomerBillableKmLogic?
  portFeeIncludedAtBooking   Boolean?
  pricingSnapshotCreatedAt   DateTime?

  notes String?

  customer       Customer        @relation(fields: [customerId], references: [id])
  customerTariff CustomerTariff? @relation(fields: [customerTariffId], references: [id], onDelete: SetNull)
  truck          Truck?          @relation(fields: [truckId], references: [id])
  driver         Driver?         @relation(fields: [driverId], references: [id])

  pickupAddress   Address? @relation("CoursePickupAddress", fields: [pickupAddressId], references: [id])
  deliveryAddress Address? @relation("CourseDeliveryAddress", fields: [deliveryAddressId], references: [id])

  stops                      CourseStop[]
  routeLegs                  RouteLeg[]
  costs                      Cost[]
  invoiceLines               InvoiceLine[]
  documents                  Document[]
  weeklyRevenueReportCourses WeeklyTruckRevenueReportCourse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([customerTariffId])
  @@index([truckId])
  @@index([driverId])
  @@index([plannedDate])
  @@index([status])
  @@index([courseType])
  @@index([settlementStatus])
  @@index([settlementCheckedAt])
}

model CourseStop {
  id        String         @id @default(cuid())
  courseId  String
  addressId String?
  sequence  Int
  type      CourseStopType
  label     String?
  notes     String?

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  address Address? @relation(fields: [addressId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, sequence])
  @@index([courseId])
  @@index([addressId])
  @@index([type])
  @@map("course_stops")
}

model RouteLeg {
  id       String @id @default(cuid())
  courseId String
  sequence Int

  fromAddressId String?
  toAddressId   String?

  description        String?
  totalDistanceKm    Decimal? @db.Decimal(10, 2)
  billableDistanceKm Decimal? @db.Decimal(10, 2)
  isBillable         Boolean  @default(true)
  notes              String?

  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  fromAddress Address? @relation("RouteLegFromAddress", fields: [fromAddressId], references: [id])
  toAddress   Address? @relation("RouteLegToAddress", fields: [toAddressId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([courseId, sequence])
  @@index([courseId])
}

model Cost {
  id          String   @id @default(cuid())
  courseId    String?
  truckId     String?
  type        CostType
  description String
  amount      Decimal  @db.Decimal(12, 2)
  costDate    DateTime @default(now())
  notes       String?

  course Course? @relation(fields: [courseId], references: [id], onDelete: Cascade)
  truck  Truck?  @relation(fields: [truckId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@index([truckId])
  @@index([type])
  @@index([costDate])
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  customerId    String
  status        InvoiceStatus @default(DRAFT)

  issueDate DateTime  @default(now())
  dueDate   DateTime?
  paidAt    DateTime?

  periodStart DateTime?
  periodEnd   DateTime?

  subtotalAmount Decimal @default(0) @db.Decimal(12, 2)
  vatAmount      Decimal @default(0) @db.Decimal(12, 2)
  totalAmount    Decimal @default(0) @db.Decimal(12, 2)

  notes String?

  customer  Customer      @relation(fields: [customerId], references: [id])
  lines     InvoiceLine[]
  documents Document[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([customerId])
  @@index([status])
  @@index([issueDate])
}

model InvoiceLine {
  id        String  @id @default(cuid())
  invoiceId String
  courseId  String?

  description String
  quantity    Decimal @default(1) @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(12, 2)
  totalPrice  Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  course  Course? @relation(fields: [courseId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([invoiceId])
  @@index([courseId])
}

model Document {
  id        String  @id @default(cuid())
  courseId  String?
  invoiceId String?

  type     DocumentType
  fileName String
  fileUrl  String?
  notes    String?

  course  Course?  @relation(fields: [courseId], references: [id])
  invoice Invoice? @relation(fields: [invoiceId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([courseId])
  @@index([invoiceId])
  @@index([type])
}

model WeeklyTruckRevenueReport {
  id String @id @default(cuid())

  year          Int
  weekNumber    Int
  weekStartDate DateTime
  weekEndDate   DateTime

  truckId                   String?
  truckNameAtReport         String
  truckLicensePlateAtReport String

  courseCount  Int     @default(0)
  totalRevenue Decimal @default(0) @db.Decimal(12, 2)

  generatedAt DateTime @default(now())
  isLocked    Boolean  @default(false)
  notes       String?

  truck   Truck?                           @relation(fields: [truckId], references: [id], onDelete: SetNull)
  courses WeeklyTruckRevenueReportCourse[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([year, weekNumber, truckId])
  @@index([year, weekNumber])
  @@index([truckId])
  @@index([weekStartDate])
  @@index([isLocked])
  @@map("weekly_truck_revenue_reports")
}

model WeeklyTruckRevenueReportCourse {
  id String @id @default(cuid())

  reportId String
  courseId String?

  courseDate DateTime

  customerNameAtReport String
  courseTypeAtReport   CourseType
  containerNumber      String?
  routeLabel           String

  tariffNameAtBooking String?

  agreedPrice   Decimal @default(0) @db.Decimal(12, 2)
  waitingAmount Decimal @default(0) @db.Decimal(12, 2)
  totalRevenue  Decimal @default(0) @db.Decimal(12, 2)

  report WeeklyTruckRevenueReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  course Course?                  @relation(fields: [courseId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([reportId, courseId])
  @@index([reportId])
  @@index([courseId])
  @@index([courseDate])
  @@map("weekly_truck_revenue_report_courses")
}

model RouteCache {
  id         String @id @default(cuid())
  cacheKey   String @unique
  providerId String

  requestJson Json
  resultJson  Json

  expiresAt DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([providerId])
  @@index([expiresAt])
  @@map("route_cache")
}